# ==============================================================================
# DYNO -- Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust if needed:
#   cp .env.example .env
#
# All values shown here are the defaults used by deploy.sh. You only need to
# uncomment and change them if you want to override a default.
#
# AWS account ID and region are auto-detected from your AWS CLI configuration
# (aws sts get-caller-identity / aws configure get region).
# ==============================================================================

# ── Project Paths ─────────────────────────────────────────────────────────────
# You generally do not need to change these unless you reorganised the repo.

# CONFIG_FILE="schema/stream-composite.json"
# SOURCE_DIR="source/functions/"
# OUTPUT_DIR="output/"
# TEMPLATE_FILE="source/orchestrator_template.py.j2"
# ASL_TEMPLATE_FILE="source/asl_template.asl.j2"
# ORCHESTRATOR_SCRIPT="source/orchestrator_generator.py"
# ASL_SCRIPT="source/asl_generator.py"
# TERRAFORM_DIR="source/terraform/"
# DYNO_REQUIREMENTS_FILE="source/python/dyno/requirements.txt"
# DYNO_LAYER_SOURCE_DIR="source/python/dyno/"

# ── AWS ───────────────────────────────────────────────────────────────────────
# Uncomment only to override auto-detection.

# AWS_REGION="us-east-1"
# AWS_ACCOUNT_ID="123456789012"
