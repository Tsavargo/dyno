# Path to the composites JSON config file
CONFIG_FILE="schema/stream-composite.json"

# Directory containing the component function modules
SOURCE_DIR="source/functions/"

# Output directory for generated orchestrators (composites land here)
OUTPUT_DIR="output/"

# Path to the Jinja2 Python template file
TEMPLATE_FILE="source/orchestrator_template.py.j2"

# Path to the Jinja2 ASL template file
ASL_TEMPLATE_FILE="source/asl_template.asl.j2"

# Paths to the Python generator scripts
ORCHESTRATOR_SCRIPT="source/orchestrator_generator.py"
ASL_SCRIPT="source/asl_generator.py"

# Path to the Terraform directory
TERRAFORM_DIR="source/terraform/"

# Path to the dyno layer requirements.txt (relative to project root)
DYNO_REQUIREMENTS_FILE="source/python/dyno/requirements.txt"

# Root directory used to build the dyno Lambda layer zip
DYNO_LAYER_SOURCE_DIR="source/python/dyno/"

# ── AWS ────────────────────────────────────────────────────────────────────────

AWS_REGION="us-east-1"
AWS_ACCOUNT_ID="267432323971"
